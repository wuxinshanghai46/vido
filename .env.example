# OpenAI API Key (用于 GPT-4o 剧情生成 + Sora 2 视频生成)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Claude API Key (申请后填入，用于替换 GPT-4o 做剧情生成)
CLAUDE_API_KEY=

# 剧情生成使用的 AI 提供商: openai 或 claude
STORY_PROVIDER=openai

# 服务端口
PORT=3000

# FFmpeg 路径 (Windows 默认安装路径，或自定义)
FFMPEG_PATH=ffmpeg

# 视频输出目录
OUTPUT_DIR=./outputs
